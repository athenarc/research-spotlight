  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3237791/13">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>Beeston St. Andrew (TG 255 140) by Alan Davison A fieldwalking survey is in progress to try and determine the location of the deserted village whose inhabitants were named in 1332, and of the long-vanished church.</so:sentence_text>
