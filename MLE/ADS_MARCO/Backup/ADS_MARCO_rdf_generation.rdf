  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3248975/266">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>Their presence is generally suggestive of an activity area connected with hide-working, especially perforating skins for sewing, although microwear analysis suggests that these tools were employed for scraping and perhaps even engraving tasks.</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/3248975"/>
  </rdf:Description>
