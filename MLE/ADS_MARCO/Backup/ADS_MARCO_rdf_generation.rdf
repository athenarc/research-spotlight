    <so:sentence_text>Special mention is made of Alan Vince (Alan Vince Archaeology Consultancy), who undertook the thin-section analysis; his death in February 2009 has deprived archaeological science of one of its leading practitioners.</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/3248982"/>
  </rdf:Description>
