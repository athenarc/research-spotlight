  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3248975/233">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>Ethnographic studies suggest that hunting is almost exclusively associated with males (Grøn 1995, 53), although the assumption that only males used projectiles during the Mesolithic has been challenged (Finlay 1997).</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/3248975"/>
