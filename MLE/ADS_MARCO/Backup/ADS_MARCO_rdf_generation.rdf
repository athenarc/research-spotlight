  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Score_(video_games)_3248978/719_65_72">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Score (video games)</so:method_name>
    <so:textual_span>scoring</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3248978/719"/>
    <so:description>In video games, score refers to an abstract quantity associated with a player or team. Score is usually measured in the abstract unit of points, and events in the game can raise or lower the score of different parties.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=78508655</so:wikipedia_url>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3253948/29">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>We research the history of Charley and its environs, and aim to make Charley more widely known throughout the UK.</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/3253948"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Palynology_3248976/996_0_22">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Palynology</so:method_name>
    <so:textual_span>Pollen identifications</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3248976/996"/>
    <so:description>Palynology is the study of microorganisms and microscopic fragments of macroorganisms that are composed of acid-resistant organic material and occur in sediments, sedimentary rocks, and even some metasedimentary rocks. Palynomorphs are the microscopic, acid-resistant organic remains and debris produced by a wide variety of plants, animals, and Protista that have existed since the late Proterozoic.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=328274</so:wikipedia_url>
  </rdf:Description>
