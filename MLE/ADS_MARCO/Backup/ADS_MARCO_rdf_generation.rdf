  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Thin_section_3248982/189_94_115">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Thin section</so:method_name>
    <so:textual_span>thin-section analysis</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3248982/189"/>
    <so:description>In optical mineralogy and petrography, a thin section (or petrographic thin section) is a thin slice of a rock or mineral sample, prepared in a laboratory, for use with a polarizing petrographic microscope, electron microscope and electron microprobe. A thin sliver of rock is cut from the sample with a diamond saw and ground optically flat.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=4351340</so:wikipedia_url>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Composition_(visual_arts)_3248978/1410_21_52">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Composition (visual arts)</so:method_name>
    <so:textual_span>horizontal and vertical combing</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3248978/1410"/>
    <so:description>In visual arts, composition (meaning "putting together") is the organization of an artwork. It is often used interchangeably with various terms such as design, form, visual ordering, or formal structure, depending on the context.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=1822919</so:wikipedia_url>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Activity/3237732/335_0_45">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Activity"/>
    <so:textual_span>The term 'LMU' is therefore used collectively</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3237732/335"/>
    <so:begin_index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</so:begin_index>
    <so:end_index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">45</so:end_index>
