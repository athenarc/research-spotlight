    <so:article_ID>https://archaeologydataservice.ac.uk/library/browse/details.xhtml?recordId=3203914</so:article_ID>
    <so:publication_year rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2017</so:publication_year>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Goal/3248978/320_93_113">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Goal"/>
    <so:textual_span>create new post-pads</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3248978/320"/>
    <so:begin_index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">93</so:begin_index>
    <so:end_index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">113</so:end_index>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3248980/8">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>As a result of the potential revealed by the evaluation stage, a project design was prepared detailing the scope of works necessary to fulfil the condition attached to the planning permission (NA 2005).</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/3248980"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Goal/3238495/4_130_212">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Goal"/>
    <so:textual_span>discern what archaeology can tell us about the activities of this overlooked craft</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3238495/4"/>
    <so:begin_index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">130</so:begin_index>
    <so:end_index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">212</so:end_index>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3248978/320">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>Some building material from the original structure was reused to infill the post-pits and to create new post-pads.</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/3248978"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3237732/335">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>The term 'LMU' is therefore used collectively to describe similar fabrics in a distinctive range of forms, but likely to represent the products of several different kiln sites.</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/3237732"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3238497/181">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>Cremation is a likely way to deal with battle dead, and this is supported in one of the stories of 12th century Saxo Grammaticus, who mentions cremation fires of large numbers of battle dead (Davidson 1979).</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/3238497"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3238492/105">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>While we cannot interrogate the protagonists of 1916 to test the theory of panoptical surveillance, the limited contemporary records and photography tend to affirm its relevance.</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/3238492"/>
  </rdf:Description>
