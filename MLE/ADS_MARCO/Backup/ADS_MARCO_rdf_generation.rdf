  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Scanning_electron_microscope_3244148/646_47_116">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Scanning electron microscope</so:method_name>
    <so:textual_span>scanning electron microscopy-energy dispersive spectrometry (SEM-EDS)</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3244148/646"/>
    <so:description>A scanning electron microscope (SEM) is a type of electron microscope that produces images of a sample by scanning the surface with a focused beam of electrons. The electrons interact with atoms in the sample, producing various signals that contain information about the surface topography and composition.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=28034</so:wikipedia_url>
  </rdf:Description>
