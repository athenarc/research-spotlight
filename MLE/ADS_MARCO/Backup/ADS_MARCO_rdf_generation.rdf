  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3244155/259">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>At the other end of the human life span, a study uses dental radiometry to investigate the stages of development and eruption of the teeth of the subadult individuals, who had been identified via the breast plates.</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/3244155"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Cartography_3248982/154_144_165">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Cartography</so:method_name>
    <so:textual_span>cartographic analysis</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3248982/154"/>
    <so:description>Cartography () is the study and practice of making and using maps. Combining science, aesthetics and technique, cartography builds on the premise that reality (or an imagined reality) can be modeled in ways that communicate spatial information effectively.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=7294</so:wikipedia_url>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Soil_test_3248979/263_58_71">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Soil test</so:method_name>
    <so:textual_span>soil sampling</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3248979/263"/>
    <so:description>A soil test is a laboratory or in-situ analysis to determine the chemical, physical or biological characteristics of a soil. Possibly the most widely conducted soil tests are those performed to estimate the plant-available concentrations of nutrients in order to provide fertilizer recommendations in agriculture.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=411781</so:wikipedia_url>
  </rdf:Description>
