    <so:end_index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">112</so:end_index>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Post-excavation_analysis_3248992/75_91_115">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Post-excavation analysis</so:method_name>
    <so:textual_span>post-excavation analysis</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3248992/75"/>
    <so:description>Post-excavation analysis constitutes processes that are used to study archaeological materials after an excavation is completed. Since the advent of "New Archaeology" in the 1960s, the use of scientific techniques in archaeology has grown in importance.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=7623330</so:wikipedia_url>
  </rdf:Description>
