  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3203917/36">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>In order to test the accuracy of the reconstructions, the network was validated against archaeologically excavated infrastructural and isolated finds not included in the previous analyses.</so:sentence_text>
