  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3248979/25">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>The aim of the project was to establish the date and character of the archaeological remains present, in order to provide a detailed archaeological record of the site prior to its destruction by the development.</so:sentence_text>
