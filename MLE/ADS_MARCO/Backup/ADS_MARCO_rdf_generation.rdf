  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/3203918">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Article"/>
    <so:title>Symbols of initiative and power? Parish church foundation in rural settlements of the Saxo-Norman Danelaw</so:title>
    <so:article_ID>https://archaeologydataservice.ac.uk/library/browse/details.xhtml?recordId=3203918</so:article_ID>
    <so:publication_year rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2017</so:publication_year>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Combing_3248978/719_53_60">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Combing</so:method_name>
    <so:textual_span>combing</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3248978/719"/>
    <so:description>Combing is a method for preparing carded fibre for spinning. Combing aligns fibers in parallel before spinning to produce a smoother, stronger, and more lustrous yarn.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=9146365</so:wikipedia_url>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Organization/Abrams_Archaeology_Ltd">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Organization"/>
    <so:organization_name>Abrams Archaeology Ltd</so:organization_name>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3238497/25">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>The method offers a means to identify first-generation migrants in the archaeological record, whereby the use of strontium isotope analysis, in particular, has been hugely successful (e.g. Bentley 2006; Groves et al. 2013; Haak et al. 2008).</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/3238497"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3248983/196">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>In the latter’s absence, optically stimulated luminescence, as used at Eynesbury (Ellis 2004, 61–62), is likely to represent the best alternative scientific dating technique.</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/3248983"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3238493/19">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>Building on an earlier paper on the spiritual landscapes of Argyll (Widell 2017), the purpose of this paper is to explore Hinba's location by contextualising Adomnán's notions on spiritual places and integrating this with analysis of the archaeological landscape.</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/3238493"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3244150/732">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>Certain age categories are employed to facilitate the interpretation of this data.</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/3244150"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Activity/3248978/1216_0_50">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Activity"/>
    <so:textual_span>At Barnack, the lack of domestic features was used</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3248978/1216"/>
    <so:begin_index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</so:begin_index>
    <so:end_index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">50</so:end_index>
    <so:has_objective rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Goal/3248978/1216_54_86"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3248979/262">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>The author is not aware of any other workshop of Roman or medieval date in this country that has been shown to use horse ribs for bone working.</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/3248979"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3238492/129">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>This perspective from a landscape planner such as Roe may help us better understand the emotional, spiritual, and possibly institutional dynamics behind the DLI crosses.</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/3238492"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Zooarchaeology_3248980/156_42_67">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Zooarchaeology</so:method_name>
    <so:textual_span>zooarchaeological methods</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3248980/156"/>
    <so:description>Zooarchaeology or archaeozoology merges the disciplines of zoology and archaeology, focusing on the analysis of animal remains within archaeological sites. This field, managed by specialists known as zooarchaeologists or faunal analysts, examines remnants such as bones, shells, hair, chitin, scales, hides, proteins, and DNA, to derive insights into historical human-animal interactions and environmental conditions.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=36860</so:wikipedia_url>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Goal/3238495/4_20_111">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Goal"/>
    <so:textual_span>examine the physical evidence for the specialist role of the glazier during the Reformation</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3238495/4"/>
    <so:begin_index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">20</so:begin_index>
    <so:end_index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">111</so:end_index>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Goal/3238497/31_112_217">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Goal"/>
    <so:textual_span>assess whether he or she is likely to have resided there during the period in which the tissue was formed</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3238497/31"/>
    <so:begin_index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">112</so:begin_index>
    <so:end_index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">217</so:end_index>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3238497/119">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>A Mann-Whitney non-parametric test confirms no statistically significant difference in isotopic ratios between the sexes (p = 0.8396, W = 20), and a T-test assuming unequal variances (variance test F=0.4475, p=0.3067) gives a similarly high p-value (p=0.8352, T=-0.2309).</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/3238497"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Person/Mark_Stephens">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Person"/>
    <so:full_name>Mark Stephens</so:full_name>
    <so:family_name>Stephens</so:family_name>
    <so:given_name>Mark</so:given_name>
    <so:is_author_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/3248989"/>
    <so:participates_in rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Activity/3248989/25_0_24"/>
    <so:has_goal rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Goal/3248989/25_28_64"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Isotope_analysis_3238497/4_6_32">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Isotope analysis</so:method_name>
    <so:textual_span>strontium isotope analysis</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3238497/4"/>
    <so:description>Isotope analysis is the identification of isotopic signature, abundance of certain stable isotopes of chemical elements within organic and inorganic compounds. Isotopic analysis can be used to understand the flow of energy through a food web, to reconstruct past environmental and climatic conditions, to investigate human and animal diets, for food authentification, and a variety of other physical, geological, palaeontological and chemical processes.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=174238</so:wikipedia_url>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Activity/3248976/27_0_57">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Activity"/>
    <so:textual_span>An intermediate level of Land-use area (e.g. L4) was used</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3248976/27"/>
    <so:begin_index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</so:begin_index>
    <so:end_index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">57</so:end_index>
    <so:has_objective rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Goal/3248976/27_61_119"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Goal/3248979/25_114_210">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Goal"/>
    <so:textual_span>provide a detailed archaeological record of the site prior to its destruction by the development</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3248979/25"/>
    <so:begin_index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">114</so:begin_index>
    <so:end_index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">210</so:end_index>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3248976/567">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>The survival of waterlogged wood within waterholes and wells G53/53.1, some of it in situ, prompted the selection of seven samples for radiocarbon dating.</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/3248976"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3238496/83">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>Elsewhere, scholars have suggested that some medieval ecclesiastical sculpture can be shown to reflect the local environment in addition to its allegorical meaning, and propose that a wide range of source material should be used in order to interpret sculpture of this nature, including bestiaries, encyclopaedias and the local landscape (den Hartog 1996, 30; Thurlby 2000, 10).</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/3238496"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Goal/3244151/14_66_184">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Goal"/>
    <so:textual_span>relieve pressure on the back of the moat wall when its inner face was being dismantled and rebuilt by the stone masons</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3244151/14"/>
    <so:begin_index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">66</so:begin_index>
    <so:end_index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">184</so:end_index>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3248976/972">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>Samples for wood species identification and radiocarbon dating were taken at this point.</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/3248976"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/3244151">
