    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3248989/25"/>
    <so:begin_index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">28</so:begin_index>
