    <so:publication_year rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2010</so:publication_year>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3244150/7">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>Geotechnical investigations consisting of ten test pits, two boreholes and one window sample were monitored by PCA under archaeological watching brief conditions (Frickers 2009) and formed the first phase of archaeological investigation (Fig 2, TP 1–7, 9–11, BH 1–2, W/S 5).</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/3244150"/>
  </rdf:Description>
