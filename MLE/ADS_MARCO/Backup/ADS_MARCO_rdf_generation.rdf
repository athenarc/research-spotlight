  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Post-excavation_analysis_3248993/36_79_103">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Post-excavation analysis</so:method_name>
    <so:textual_span>post-excavation analysis</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3248993/36"/>
    <so:description>Post-excavation analysis constitutes processes that are used to study archaeological materials after an excavation is completed. Since the advent of "New Archaeology" in the 1960s, the use of scientific techniques in archaeology has grown in importance.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=7623330</so:wikipedia_url>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Bone_grafting_3248978/969_102_114">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Bone grafting</so:method_name>
    <so:textual_span>bone-working</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3248978/969"/>
    <so:description>Bone grafting is a type of transplantation used to replace missing bone tissue or stimulate the healing of fractures. This surgical procedure is useful for repairing bone fractures that are extremely complex, pose a significant health risk to the patient, or fail to heal properly, leading to pseudoarthrosis.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=2518882</so:wikipedia_url>
  </rdf:Description>
