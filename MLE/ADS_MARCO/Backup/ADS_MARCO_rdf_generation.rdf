  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Scaling_(geometry)_3248978/1410_82_89">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Scaling (geometry)</so:method_name>
    <so:textual_span>scoring</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3248978/1410"/>
    <so:description>In affine geometry, uniform scaling (or isotropic scaling) is a linear transformation that enlarges (increases) or shrinks (diminishes) objects by a scale factor that is the same in all directions (isotropically). The result of uniform scaling is similar (in the geometric sense) to the original.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=651752</so:wikipedia_url>
  </rdf:Description>
