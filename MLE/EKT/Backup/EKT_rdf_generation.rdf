  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/13796/19">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>The purpose of this study was to determine, using morphological and molecular tools, the taxonomic status and identify this presumed hybrid specimen.</so:sentence_text>
