  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Topic/early_detection">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Topic"/>
    <so:topic_name>early detection</so:topic_name>
    <so:is_topic_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/22853"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/13796/27">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>PCR reactions were carried out in 25 µl reaction volumes containing 1× PCR buffer (including 1.5 mM MgCl2), 0.2 mM of each dNTP, 1 µM of each primer, 1 unit of Super-Term Taq polymerase (Hoffmann-La Roche), and about 100 ng of template DNA.</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/13796"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/12037/27">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>The total number of EOFs to be calculated is determined by cross-validation: a few valid data (usually 1% of the total data) are taken apart at the beginning of the procedure, and flagged as missing.</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/12037"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/12040/18">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>Cyberinfrastructure tools are emerging to help solve the problems, and ideally insert instrumentation metadata at the moment of acquisition.</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/12040"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Organization/University_of_Salento">
