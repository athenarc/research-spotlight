  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/12287/24">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>Taxa are listed alphabetically, in order to make their detection easier.</so:sentence_text>
