  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/12037/32">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>Comparison with a global Optimal Interpolation (OI) technique showed that DINEOF was up to 30 times faster in solving the missing data problem, and with a similar accuracy when compared to in situ data.</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/12037"/>
  </rdf:Description>
