    <so:has_objective rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Goal/23674/278_92_136"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/12037/22">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>The bases of the method are established in BECKERS and RIXEN (2003), which consist of an iterative method to calculate the field values at missing positions: first, a spatial and temporal mean is removed from the analyzed data, and the missing data are initialised to zero.</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/12037"/>
  </rdf:Description>
