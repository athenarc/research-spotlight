  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Experimental_biology_12302/48_56_88">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Experimental biology</so:method_name>
    <so:textual_span>experimental and culture studies</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/12302/48"/>
    <so:description>Experimental biology encompasses a set of approaches within the field of biology focused on conducting experiments to investigate and understand biological phenomena. This term contrasts with theoretical biology, which deals with mathematical modeling and abstractions of biological systems.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=41442761</so:wikipedia_url>
  </rdf:Description>
