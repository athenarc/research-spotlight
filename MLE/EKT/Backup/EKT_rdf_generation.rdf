    <so:title>Data Interpolating Empirical Orthogonal Functions (DINEOF): a tool for geophysical data analyses</so:title>
    <so:article_ID>https://ejournals.epublishing.ekt.gr/index.php/hcmr_med_mar_sc/article/view/12037</so:article_ID>
