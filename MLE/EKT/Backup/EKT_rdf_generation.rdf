  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Evolutionary_computation_13796/38_0_21">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Evolutionary computation</so:method_name>
    <so:textual_span>Evolutionary analyses</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/13796/38"/>
    <so:description>Evolutionary computation from computer science is a family of algorithms for global optimization inspired by biological evolution, and a subfield of computational intelligence and soft computing studying these algorithms. In technical terms, they are a family of population-based trial and error problem solvers with a metaheuristic or stochastic optimization character.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=268020</so:wikipedia_url>
  </rdf:Description>
