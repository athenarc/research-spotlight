  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Nowcasting_(meteorology)_12045/98_73_89">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Nowcasting (meteorology)</so:method_name>
    <so:textual_span>nowcast analyses</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/12045/98"/>
    <so:description>Nowcasting is weather forecasting on a very short term mesoscale period of up to 2 hours, according to the World Meteorological Organization, and up to six hours, according to other authors in the field. This forecast is an extrapolation in time of known weather parameters, including those obtained by means of remote sensing, using techniques that take into account a possible evolution of the air mass.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=30230871</so:wikipedia_url>
  </rdf:Description>
