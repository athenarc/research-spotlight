    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/12045/94"/>
    <so:description>Pressure measurement is the measurement of an applied force per unit area by a fluid (liquid or gas) on a surface. Pressure is typically expressed in units of pascals in the International System of Units (SI).</so:description>
