  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Activity/23674/278_0_136">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Activity"/>
    <so:textual_span>Following the extraction of total genomic DNA, the ‘barcoding gene’ COI mtDNA was amplified for taxonomic identification and comparisons</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/23674/278"/>
    <so:begin_index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</so:begin_index>
