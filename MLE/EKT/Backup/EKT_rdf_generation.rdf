  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Activity/12347/21_0_154">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Activity"/>
    <so:textual_span>Collected specimens were transported alive to the laboratory, anaesthetized in a 7.5% MgCl₂ solution isotonic with seawater and extracted from their tubes</so:textual_span>
