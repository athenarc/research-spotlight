  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Activity/13796/33_0_233">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Activity"/>
    <so:textual_span>PCR reactions were carried out as described above with the following thermal regime: an initial step of 2 min at 95°C followed by 32 cycles of 45 s at 94°C, 45 s at 55°C and 45 s at 72°C, followed by 3 min at 72°C and then held at 15</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/13796/33"/>
    <so:begin_index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</so:begin_index>
