    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>More elaborated techniques have been devised to improve the performance of seasonal VBGF fittings for data from tagging experiments (FRANCIS 1988), or size-at-age data (PAULY et al. 1992).</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/12070"/>
