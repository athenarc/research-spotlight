    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Activity"/>
    <so:textual_span>Cross checking among different data types e.g. MBT with XBT performed manually only to a limited sample of the data without revealing any duplicates</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/12039/54"/>
    <so:begin_index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</so:begin_index>
    <so:end_index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">148</so:end_index>
    <so:employs rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Cross-validation_(statistics)_12039/54_0_14"/>
    <so:employs rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Multivariate_normal_distribution_12039/54_47_50"/>
    <so:employs rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Cross-validation_(statistics)_12039/54_56_59"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/12224/38">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>Faunal affinity between stations was measured by regrouping the stations on the basis of Euclidean distance (LEGENDRE &amp; LEGENDRE, 1998).</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/12224"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/12039/54">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>Cross checking among different data types e.g. MBT with XBT performed manually only to a limited sample of the data without revealing any duplicates.</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/12039"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Organization/Bogazici_Üniversitesi_-_Güney_Kampüsü">
