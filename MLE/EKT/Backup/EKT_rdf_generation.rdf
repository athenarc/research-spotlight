  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Elementary_function_12037/23_109_126">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Elementary function</so:method_name>
    <so:textual_span>EOF decomposition</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/12037/23"/>
    <so:description>In mathematics, an elementary function is a function of a single variable (real or complex) that is typically encountered by beginners. The basic elementary functions are polynomial functions, rational functions, the trigonometric functions, the exponential and logarithm functions, the n-th root, and the inverse trigonometric functions, as well as those functions obtained by addition, multiplication, division, and composition of these.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=10412</so:wikipedia_url>
  </rdf:Description>
