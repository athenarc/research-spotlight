  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Snorkeling_12034/19_102_112">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Snorkeling</so:method_name>
    <so:textual_span>snorkeling</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/12034/19"/>
    <so:description>Snorkeling (snorkelling in British and Commonwealth English) is the practice of swimming face-down in a body of water while breathing the ambient air through a shaped tube called a snorkel, usually with swimming goggles or a diving mask, and swimfins. In cooler waters, a wetsuit is also worn.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=66733</so:wikipedia_url>
  </rdf:Description>
