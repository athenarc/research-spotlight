  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/12305/27">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>Using ImageJ (NIH), we extracted the average distance travelled per punt (in disc length (DL)), speed per punt (DLs $ ^{-1} $), and frequency of punts during a continuous period of pelvic fin locomotion, following Macesic &amp; Kajiura (2010).</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/12305"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Morphology_(biology)_23674/143_31_56">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Morphology (biology)</so:method_name>
    <so:textual_span>morphological examination</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/23674/143"/>
    <so:description>In biology, morphology is the study of the form and structure of organisms and their specific structural features. This includes aspects of the outward appearance (shape, structure, color, pattern, size), as well as the form and structure of internal parts like bones and organs, i.e., anatomy.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=1099348</so:wikipedia_url>
  </rdf:Description>
