  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Geomorphology_18914/28_4_17">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Geomorphology</so:method_name>
    <so:textual_span>geomorphology</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/18914/28"/>
    <so:description>Geomorphology (from Ancient Greek γῆ (gê) 'earth'; μορφή (morphḗ) 'form' and λόγος (lógos) 'study') is the scientific study of the origin and evolution of topographic and bathymetric features generated by physical, chemical or biological processes operating at or near Earth's surface. Geomorphologists seek to understand why landscapes look the way they do, to understand landform and terrain history and dynamics and to predict changes through a combination of field observations, physical experiments and numerical modeling.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=78534</so:wikipedia_url>
  </rdf:Description>
