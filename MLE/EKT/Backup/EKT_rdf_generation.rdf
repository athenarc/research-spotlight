  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Meiobenthos_12224/17_4_22">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Meiobenthos</so:method_name>
    <so:textual_span>meiofauna analysis</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/12224/17"/>
    <so:description>Meiobenthos, also called meiofauna, are small benthic invertebrates that live in marine or freshwater environments, or both. The term meiofauna loosely defines a group of organisms by their size—larger than microfauna but smaller than macrofauna—rather than by their taxonomy.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=212379</so:wikipedia_url>
  </rdf:Description>
