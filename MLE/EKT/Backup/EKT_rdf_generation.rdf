    <so:sentence_text>Taxa are listed alphabetically, in order to make their detection easier, but when infraspecific taxa are listed, the autonym, if present, is cited first.</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/12516"/>
  </rdf:Description>
