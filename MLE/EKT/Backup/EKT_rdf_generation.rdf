  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/13080/36">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>A scatter plot between $ \log(a) $ and b values was drawn for most reported species to determine the outlier values present in LWR, from, which outliers should be identified and those relationships must be considered problematic (Stergiou &amp; Moutopoulos, 2001; Froese, 2000).</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/13080"/>
  </rdf:Description>
