    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>A series of ROV dives were carried out during 2018 aboard the Ketch Catamaran Ranger by Oceana to explore the archipelago's mesophotic and bathyal seabed.</so:sentence_text>
