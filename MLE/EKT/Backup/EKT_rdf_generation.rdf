  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/12037/97">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>DINEOF reconstructions have been compared with independent data in several applications, giving similar or even better results than those obtained with other reconstruction methods such as optimal interpolation.</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/12037"/>
  </rdf:Description>
