  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/18914/28">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>The geomorphology of the area is governed by cemented aeoli an sandstone that forms a rocky substrate locally known as “Kurkar”, rich with crevices, ledges and caves.</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/18914"/>
  </rdf:Description>
