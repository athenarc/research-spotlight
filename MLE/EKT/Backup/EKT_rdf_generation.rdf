  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Activity/13796/27_0_239">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Activity"/>
    <so:textual_span>PCR reactions were carried out in 25 µl reaction volumes containing 1× PCR buffer (including 1.5 mM MgCl2), 0.2 mM of each dNTP, 1 µM of each primer, 1 unit of Super-Term Taq polymerase (Hoffmann-La Roche), and about 100 ng of template DNA</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/13796/27"/>
    <so:begin_index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</so:begin_index>
    <so:end_index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">239</so:end_index>
    <so:employs rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Polymerase_chain_reaction_13796/27_0_3"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/12302/47">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>Molecular analysis and culture studies comparing the Mediterranean material of Ulonema and the Atlantic species should be carried out for progress.</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/12302"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/12037/23">
