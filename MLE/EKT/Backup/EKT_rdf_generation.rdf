  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/11617">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Article"/>
    <so:title>New hosts for the pyriform scale Protopulvinaria pyriformis (Cockerell) (Hemiptera: Coccidae) in Greece</so:title>
    <so:article_ID>https://ejournals.epublishing.ekt.gr/index.php/entsoc/article/view/11617</so:article_ID>
    <so:publication_year rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2008</so:publication_year>
    <so:publisher>Entomologia Hellenica</so:publisher>
    <so:doctype>['Scientific article', 'Publication in journal']</so:doctype>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/13796/71">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>These primers were not general enough and DNA from some of the species, like D. cervinus, were not amplified, using the initial PCR protocol.</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/13796"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/13080/32">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>For determination of whether $b$ value is different from 3, student $t$-test was applied.</so:sentence_text>
