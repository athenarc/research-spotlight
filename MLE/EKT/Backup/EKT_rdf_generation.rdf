  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Activity/13080/27_0_129">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Activity"/>
    <so:textual_span>Both LWR parameters, a and b, were tested at the family level and compared per study area using one way variance analysis (ANOVA)</so:textual_span>
