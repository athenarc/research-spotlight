  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Vertex_(anatomy)_12034/18_0_24">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Vertex (anatomy)</so:method_name>
    <so:textual_span>Presence/absence surveys</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/12034/18"/>
    <so:description>In arthropod and vertebrate anatomy, the vertex (or cranial vertex) is the highest point of the head. In humans, the vertex is formed by four bones of the skull: the frontal bone, the two parietal bones, and the occipital bone.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=11332956</so:wikipedia_url>
  </rdf:Description>
