  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Analysis_of_covariance_12419/22_20_26">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Analysis of covariance</so:method_name>
    <so:textual_span>ANCOVA</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/12419/22"/>
    <so:description>Analysis of covariance (ANCOVA) is a general linear model that blends ANOVA and regression. ANCOVA evaluates whether the means of a dependent variable (DV) are equal across levels of one or more categorical independent variables (IV) and across one or more continuous variables.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=404926</so:wikipedia_url>
  </rdf:Description>
