  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Log-normal_distribution_13080/75_37_60">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Log-normal distribution</so:method_name>
    <so:textual_span>log-normal distribution</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/13080/75"/>
    <so:description>In probability theory, a log-normal (or lognormal) distribution is a continuous probability distribution of a random variable whose logarithm is normally distributed. Thus, if the random variable X is log-normally distributed, then Y = ln X has a normal distribution.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=102476</so:wikipedia_url>
  </rdf:Description>
