    <so:method_name>Statistical model</so:method_name>
    <so:textual_span>statistical modelling</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3248976/908"/>
    <so:description>A statistical model is a mathematical model that embodies a set of statistical assumptions concerning the generation of sample data (and similar data from a larger population). A statistical model represents, often in considerably idealized form, the data-generating process.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=27576</so:wikipedia_url>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Radiocarbon_dating_3248983/269_55_73">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Radiocarbon dating</so:method_name>
    <so:textual_span>radiocarbon dating</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3248983/269"/>
    <so:description>Radiocarbon dating (also referred to as carbon dating or carbon-14 dating) is a method for determining the age of an object containing organic material by using the properties of radiocarbon, a radioactive isotope of carbon. The method was developed in the late 1940s at the University of Chicago by Willard Libby.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=26197</so:wikipedia_url>
  </rdf:Description>
