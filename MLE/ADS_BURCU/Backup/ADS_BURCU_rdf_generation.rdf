  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Inductively_coupled_plasma_mass_spectrometry_3248982/70_76_115">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Inductively coupled plasma mass spectrometry</so:method_name>
    <so:textual_span>Inductively-Coupled Plasma Spectroscopy</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3248982/70"/>
    <so:description>Inductively coupled plasma mass spectrometry (ICP-MS) is a type of mass spectrometry that uses an inductively coupled plasma to ionize the sample. It atomizes the sample and creates atomic and small polyatomic ions, which are then detected.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=49503</so:wikipedia_url>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Activity/3248976/908_125_218">
