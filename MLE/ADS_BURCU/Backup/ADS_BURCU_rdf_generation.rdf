  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3238495/73">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>It is often assumed, in the face of little supporting evidence, that such hearths were used during the Dissolution for cupellation, to extract naturally occurring silver from the lead, thus maximising the value of the recycled material (e.g. James 1997, 168; Thomas 2006, 206-9).</so:sentence_text>
