  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3248977/522">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>The chronology of the site is difficult to ascertain due to the lack of stratigraphy, the mix of pottery fabrics and wares which range in date from the late 1st century BC to the early 2nd century AD, and the lack of dating for the inhumation burials.</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/3248977"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Activity/3203925/16_0_154">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Activity"/>
    <so:textual_span>Patterns emerging from these bioarchaeological data will then be compared with the evidence from excavated farms—buildings, enclosures, droveways, etc.—to</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3203925/16"/>
    <so:begin_index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</so:begin_index>
    <so:end_index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">154</so:end_index>
    <so:has_objective rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Goal/3203925/16_155_250"/>
  </rdf:Description>
