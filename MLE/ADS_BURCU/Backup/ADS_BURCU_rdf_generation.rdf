  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Stabbing_3248978/1453_62_70">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Stabbing</so:method_name>
    <so:textual_span>stabbing</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3248978/1453"/>
    <so:description>A stabbing is penetration or rough contact with a sharp or pointed object at close range. Stab connotes purposeful action, as by an assassin or murderer, but it is also possible to accidentally stab oneself or others.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=618009</so:wikipedia_url>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Isotope_analysis_3238497/46_76_102">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Isotope analysis</so:method_name>
    <so:textual_span>strontium isotope analyses</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3238497/46"/>
    <so:description>Isotope analysis is the identification of isotopic signature, abundance of certain stable isotopes of chemical elements within organic and inorganic compounds. Isotopic analysis can be used to understand the flow of energy through a food web, to reconstruct past environmental and climatic conditions, to investigate human and animal diets, for food authentification, and a variety of other physical, geological, palaeontological and chemical processes.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=174238</so:wikipedia_url>
  </rdf:Description>
