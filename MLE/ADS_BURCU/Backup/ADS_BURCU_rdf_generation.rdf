    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Activity"/>
    <so:textual_span>Twenty-nine oat grains from nine samples were counted</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3248979/377"/>
    <so:begin_index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</so:begin_index>
    <so:end_index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">53</so:end_index>
    <so:has_objective rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Goal/3248979/377_116_194"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3203916/98">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>The model could, for example, be used to stratify sampling sites for pollen analysis.</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/3203916"/>
  </rdf:Description>
