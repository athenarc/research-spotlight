    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>For this study, 50 individuals were sampled for strontium isotope analysis (Table 2).</so:sentence_text>
