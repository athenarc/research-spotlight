  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3203916/15">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>Thus, field-names are also a valuable source for reconstructing patterns of medieval agriculture and land-use that should be placed alongside more traditional research methods, such as field-walking, topographic survey, and test-pitting.</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/3203916"/>
  </rdf:Description>
