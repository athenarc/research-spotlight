  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Geophysical_survey_(archaeology)_3248990/202_56_74">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Geophysical survey (archaeology)</so:method_name>
    <so:textual_span>geophysical survey</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3248990/202"/>
    <so:description>In archaeology, geophysical survey is ground-based physical sensing techniques used for archaeological imaging or mapping. Remote sensing and marine surveys are also used in archaeology, but are generally considered separate disciplines.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=275496</so:wikipedia_url>
  </rdf:Description>
