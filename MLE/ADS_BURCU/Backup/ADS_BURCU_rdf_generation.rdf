  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Environmental_impact_assessment_3248990/325_32_54">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Environmental impact assessment</so:method_name>
    <so:textual_span>environmental analysis</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3248990/325"/>
    <so:description>Environmental impact assessment (EIA) is the assessment of the environmental consequences of a plan, policy, program, or actual projects prior to the decision to move forward with the proposed action. In this context, the term "environmental impact assessment" is usually used when applied to actual projects by individuals or companies and the term "strategic environmental assessment" (SEA) applies to policies, plans and programmes most often proposed by organs of state.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=2364800</so:wikipedia_url>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Person/Andy_Seaman">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Person"/>
    <so:full_name>Andy Seaman</so:full_name>
