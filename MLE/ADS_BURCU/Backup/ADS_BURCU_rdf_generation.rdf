    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Article"/>
    <so:title>Archaeological Investigations at Ironmonger Row Baths, 1-11 Ironmonger Row, Islington</so:title>
