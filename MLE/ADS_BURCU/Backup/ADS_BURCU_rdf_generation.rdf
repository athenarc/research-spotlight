  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3238493/117">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>The above analysis attempted to present Hinba from Adomnán's mindset, involving his perceptions and the events that fashioned Hinba's spiritual narrative.</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/3238493"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Bayesian_inference_3248976/575_2_19">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Bayesian inference</so:method_name>
    <so:textual_span>Bayesian approach</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3248976/575"/>
    <so:description>Bayesian inference ( BAY-zee-ən or BAY-zhən) is a method of statistical inference in which Bayes' theorem is used to calculate a probability of a hypothesis, given prior evidence, and update it as more information becomes available. Fundamentally, Bayesian inference uses a prior distribution to estimate posterior probabilities.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=49571</so:wikipedia_url>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3244155/265">
