  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3248978/1453">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>Decoration comprises burnished horizontal and vertical lines, stabbing, combed patterns, horizontal grooves, cordons, overall burnishing, overall external black slip and slipped bands / zones.</so:sentence_text>
