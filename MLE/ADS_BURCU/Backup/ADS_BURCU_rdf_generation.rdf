    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>Recent osteological analysis shows that trauma was relatively common among this group, with several individuals showing evidence of violent injury (Bob Stoddart, pers.</so:sentence_text>
