    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>Tom Higham and Alan Hogg of the University of Waikato Radiocarbon Dating Laboratory, New Zealand gave advice on and carried out radiometric carbon dating.</so:sentence_text>
