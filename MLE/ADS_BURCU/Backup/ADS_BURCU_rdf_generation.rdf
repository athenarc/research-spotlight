  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Geographic_Names_Information_System_3238494/281_113_116">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Geographic Names Information System</so:method_name>
    <so:textual_span>GPR</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3238494/281"/>
    <so:description>The Geographic Names Information System (GNIS) is a database of name and location information about more than two million physical and cultural features, encompassing the United States; the associated states of the Marshall Islands, Micronesia, Palau, and Antarctica. It is a type of gazetteer.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=351656</so:wikipedia_url>
  </rdf:Description>
