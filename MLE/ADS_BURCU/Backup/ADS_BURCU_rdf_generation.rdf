    <so:sentence_text>This approach might also have a better chance of producing material suitable for radiocarbon dating.</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/3248983"/>
  </rdf:Description>
