    <so:publication_year rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2015</so:publication_year>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Cremation_3248977/537_80_97">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Cremation</so:method_name>
    <so:textual_span>cremation burials</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/3248977/537"/>
    <so:description>Cremation is a method of final disposition of a corpse through burning. Cremation may serve as a funeral or post-funeral rite and as an alternative to burial.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=175142</so:wikipedia_url>
  </rdf:Description>
