    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>A tachymetric survey of brushed and trowel-enhanced wall tops was juxtaposed with aerial kite photographs to produce an improved site plan [Fig.2].</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/01.3001.0010.0033"/>
  </rdf:Description>
