    <so:textual_span>In the southeastern corner of Corridor 16, a test trench (1.50 m by 2.00 m) was opened</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/01.3001.0010.1824/9"/>
