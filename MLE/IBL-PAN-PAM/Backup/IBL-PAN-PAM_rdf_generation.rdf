  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Matrix_metalloproteinase_01.3001.0013.2016/59_4_16">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Matrix metalloproteinase</so:method_name>
    <so:textual_span>MGR-analysis</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/01.3001.0013.2016/59"/>
    <so:description>Matrix metalloproteinases (MMPs), also known as matrix metallopeptidases or matrixins, are metalloproteinases that are calcium-dependent zinc-containing endopeptidases; other family members are adamalysins, serralysins, and astacins. The MMPs belong to a larger family of proteases known as the metzincin superfamily.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=66077784</so:wikipedia_url>
  </rdf:Description>
