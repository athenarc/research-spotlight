  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Radiocarbon_dating_01.3001.0010.1870/7_27_46">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Radiocarbon dating</so:method_name>
    <so:textual_span>OSL and IRSL dating</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/01.3001.0010.1870/7"/>
    <so:description>Radiocarbon dating (also referred to as carbon dating or carbon-14 dating) is a method for determining the age of an object containing organic material by using the properties of radiocarbon, a radioactive isotope of carbon. The method was developed in the late 1940s at the University of Chicago by Willard Libby.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=26197</so:wikipedia_url>
  </rdf:Description>
