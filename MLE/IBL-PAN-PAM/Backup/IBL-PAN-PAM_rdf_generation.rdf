  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/01.3001.0012.1783/10">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>The variety of archaeological features and the poor state of preservation of archaeological sites in Gebelein required a new method for conducting the pottery and anthropological surveys to deal with the material (Chyla, Ejsmond et al. 2017).</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/01.3001.0012.1783"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/01.3001.0010.0177/18">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>Thermal analysis of all the samples demonstrated a relatively small weight loss in temperatures up to $ 1 0 5^{\circ} \mathrm{C} $ usually not exceeding 0.20% of the total weight [Table1, Fig.3].</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/01.3001.0010.0177"/>
  </rdf:Description>
