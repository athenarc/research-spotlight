  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/01.3001.0010.0066/24">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>Ataphonomic analysis of faunal remains from Banganarti has also shed new light on ways of meat preparation other than those already known from Dongola (Osypińska 2004; 2013; 2014).</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/01.3001.0010.0066"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/01.3001.0010.0096/3">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>This paper presents the first stage of a research project aimed at carrying out a ground survey and test excavations in the Affad region.</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/01.3001.0010.0096"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Wavelength-dispersive_X-ray_spectroscopy_01.3001.0013.2016/91_21_70">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Wavelength-dispersive X-ray spectroscopy</so:method_name>
    <so:textual_span>WD-XRF (wavelength-dispersive X-ray fluorescence)</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/01.3001.0013.2016/91"/>
    <so:description>Wavelength-dispersive X-ray spectroscopy (WDXS or WDS) is a non-destructive analysis technique used to obtain elemental information about a range of materials by measuring characteristic x-rays within a small wavelength range. The technique generates a spectrum in which the peaks correspond to specific x-ray lines, and elements can be easily identified.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=682635</so:wikipedia_url>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Goal/uw.2083-537X.pam30.2.21/11_140_188">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Goal"/>
    <so:textual_span>describe the frequency of vessel types and sizes</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/uw.2083-537X.pam30.2.21/11"/>
    <so:begin_index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">140</so:begin_index>
    <so:end_index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">188</so:end_index>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Geophysical_survey_(archaeology)_01.3001.0012.1802/10_51_69">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Geophysical survey (archaeology)</so:method_name>
    <so:textual_span>geophysical survey</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/01.3001.0012.1802/10"/>
    <so:description>In archaeology, geophysical survey is ground-based physical sensing techniques used for archaeological imaging or mapping. Remote sensing and marine surveys are also used in archaeology, but are generally considered separate disciplines.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=275496</so:wikipedia_url>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Archaeological_science_uw.2083-537X.pam32.1.07/32_56_78">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Archaeological science</so:method_name>
    <so:textual_span>archaeometric analysis</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/uw.2083-537X.pam32.1.07/32"/>
    <so:description>Archaeological science consists of the application of scientific techniques to the analysis of archaeological materials and sites. It is related to methodologies of archaeology.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=912551</so:wikipedia_url>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Activity/01.3001.0010.0085/11_0_21">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Activity"/>
