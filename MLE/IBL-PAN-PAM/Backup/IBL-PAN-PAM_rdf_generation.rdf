  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Remote_sensing_uw.2083-537X.pam32.2.04/11_87_101">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Remote sensing</so:method_name>
    <so:textual_span>remote sensing</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/uw.2083-537X.pam32.2.04/11"/>
    <so:description>Remote sensing is the acquisition of information about an object or phenomenon without making physical contact with the object, in contrast to in situ or on-site observation. The term is applied especially to acquiring information about Earth and other planets.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=228148</so:wikipedia_url>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Frequency_analysis_01.3001.0010.3014/20_0_18">
