    <so:textual_span>indicate the areas of further interest for the application of the Level III ("investigation") survey</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/uw.2083-537X.pam32.2.04/15"/>
    <so:begin_index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">81</so:begin_index>
    <so:end_index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">181</so:end_index>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Ground-penetrating_radar_01.3001.0009.9720/5_0_24">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Ground-penetrating radar</so:method_name>
    <so:textual_span>Ground Penetrating Radar</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/01.3001.0009.9720/5"/>
    <so:description>Ground-penetrating radar (GPR) is a geophysical method that uses radar pulses to image the subsurface. It is a non-intrusive method of surveying the sub-surface to investigate underground utilities such as concrete, asphalt, metals, pipes, cables or masonry.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=1180985</so:wikipedia_url>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/01.3001.0012.1817/10">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>Marine mollusk shells, stone, faience and glass were used to produce the beads found in the three el-Zuma tombs.</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/01.3001.0012.1817"/>
  </rdf:Description>
