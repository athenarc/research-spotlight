    <so:description>In archaeology, excavation is the exposure, processing, and recording of archaeological remains. An excavation site or "dig" is the area being studied.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=63994133</so:wikipedia_url>
  </rdf:Description>
