  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/01.3001.0010.0087/13">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
