    <so:sentence_text>The identified sites were documented with photographs, written descriptions and, in most cases, measurements necessary to plot a contour plan of the site.</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/01.3001.0012.1810"/>
  </rdf:Description>
