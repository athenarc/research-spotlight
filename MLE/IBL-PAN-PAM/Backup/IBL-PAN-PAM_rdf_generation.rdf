  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/01.3001.0012.1802/10">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>Probes dug in May 2015 verified the results of the geophysical survey and established a chronological phasing for this part of ancient Capitolias.</so:sentence_text>
