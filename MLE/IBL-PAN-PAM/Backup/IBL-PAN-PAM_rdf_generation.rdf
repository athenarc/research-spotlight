  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/01.3001.0009.9911">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Article"/>
    <so:title>Deir el-Bahari. Temple of Tuthmosis III, campaigns 2012–2013</so:title>
    <so:article_ID>https://doi.org/10.5604/01.3001.0009.9911</so:article_ID>
    <so:abstract>In 2012 and 2013 the mission continued research and documentation work, concentrating on scenes located in the Hypostyle Hall, the Bark Room, and rooms D, G and H. Dozens of painted stone fragments were cleaned and protected. Photoscanning techniques were used to improve detailed rendering of the temple. New photomontages were produced and subsequent walls were drawn, joining previously separate scenes.</so:abstract>
    <so:publication_year>2015</so:publication_year>
    <so:publisher>University of Warsaw: Polish Centre of Mediterranean Archaeology and University of Warsaw Press</so:publisher>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/uw.2083-537X.pam33.10/23">
