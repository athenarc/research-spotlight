  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/uw.2083-537X.pam32.2.04/11">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>The present project applied complementary prospection methods, including fieldwalking, remote sensing, and multi-method archaeo-geophysical surveys for the purpose of collecting a variety of data in order to reconstruct the ancient landscape in and around the fort.</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/uw.2083-537X.pam32.2.04"/>
