  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Digital_photography_01.3001.0012.1776/3_61_80">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Digital photography</so:method_name>
    <so:textual_span>digital photography</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/01.3001.0012.1776/3"/>
    <so:description>Digital photography uses cameras containing arrays of electronic photodetectors interfaced to an analog-to-digital converter (ADC) to produce images focused by a lens, as opposed to an exposure on photographic film. The digitized image is stored as a computer file ready for further digital processing, viewing, electronic publishing, or digital printing.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=3616597</so:wikipedia_url>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/uw.2083-537X.pam33.03/24">
