  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Scintillation_(physics)_01.3001.0013.2016/76_21_33">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Scintillation (physics)</so:method_name>
    <so:textual_span>firing tests</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/01.3001.0013.2016/76"/>
    <so:description>In condensed matter physics, scintillation ( SIN-til-ay-shun)—also termed radioluminescence—is the physical process where a material, called a scintillator, emits ultraviolet or visible light under excitation from high energy photons (X-rays or gamma rays) or energetic particles (such as electrons, alpha particles, neutrons, or ions).</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=826258</so:wikipedia_url>
  </rdf:Description>
