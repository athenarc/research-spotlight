    <so:sentence_text>Chemical analysis by WD-XRF (wavelength-dispersive X-ray fluorescence) was used to determine the content of major elements, including phosphorus and a rough estimation of sulphur and chlorine.</so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/01.3001.0013.2016"/>
  </rdf:Description>
