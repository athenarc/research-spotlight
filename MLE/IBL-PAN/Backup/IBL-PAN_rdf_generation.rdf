  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Multinomial_probit_861/461_69_103">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Multinomial probit</so:method_name>
    <so:textual_span>factorial multinomial probit model</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/861/461"/>
    <so:description>In statistics and econometrics, the multinomial probit model is a generalization of the probit model used when there are several possible categories that the dependent variable can fall into. As such, it is an alternative to the multinomial logit model as one method of multiclass classification.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=14758355</so:wikipedia_url>
  </rdf:Description>
