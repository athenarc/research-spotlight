    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>The aim of this article was to use analysis of archaeological material and its perceptional image for the interpretation and verification of its social reconstruction. </so:sentence_text>
