    <so:sentence_text>The Positive and Negative Affect Schedule (PANAS) and Modified Wellbeing Scale (MWS) have been tested and refined for use within a heritage context. </so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/636799"/>
  </rdf:Description>
