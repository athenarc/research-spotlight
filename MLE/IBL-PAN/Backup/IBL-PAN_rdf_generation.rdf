    <so:employs rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Levallois_technique_442398/120_28_47"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Goal/cc5ae513e3991e71c37f795f8d1d2796/34_90_116">
