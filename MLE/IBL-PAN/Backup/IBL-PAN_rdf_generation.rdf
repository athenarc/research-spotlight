  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/0a27969f41784b4594db2ec4c0b84d41/41">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>A total of 5 kilos of bird droppings was collected from 35 domestic pigeons in various locations in the Şendreni area, Galati County from February to March 2010 in order to obtain a representative sample for the present study, after previous grinding and mixing. </so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/0a27969f41784b4594db2ec4c0b84d41"/>
