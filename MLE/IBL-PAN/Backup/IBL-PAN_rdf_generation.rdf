  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/636799/126">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>To assess the impact of digital museum resources on participant wellbeing during the pandemic, quantitative findings underwent numerical and statistical analysis. </so:sentence_text>
