    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>For fatigue tests, 15 specimens from both melts were used to determine the fatigue characteristics (relationship between the amplitude of stress σₐ and number of cycles to failure Nₑ as well as fatigue strength) (Uhričik et al., 2018). </so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/88535"/>
