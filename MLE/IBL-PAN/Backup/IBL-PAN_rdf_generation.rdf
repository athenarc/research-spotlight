  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Multiprotocol_Label_Switching_publications_20d1a925-674f-4f69-8eff-4ed258dc2c2c/296_80_111">
