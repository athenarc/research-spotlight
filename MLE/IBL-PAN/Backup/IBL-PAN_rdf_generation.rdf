  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/b3f5ede431eb4e63b5dcf75ef940187b">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Article"/>
    <so:title>The Suitability of the DMA Method for the Characterization of Recent and Historical Parchments and Leathers</so:title>
    <so:article_ID>oai:doaj.org_article:b3f5ede431eb4e63b5dcf75ef940187b</so:article_ID>
    <so:abstract>The dynamical mechanical analysis (DMA) technique was used for the characterization of some recently manufactured and historical parchments and leathers. The obtained results were correlated with the DSC measurements performed for these biomaterials. We point out the suitability of the DMA method for distinguishing qualitatively between a recently manufactured leather and a patrimonial one, as well as for assessing the deterioration of the parchments and leathers as a result of natural ageing.</so:abstract>
    <so:publication_year rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</so:publication_year>
    <so:publisher>['Alexandru Ioan Cuza University of Iasi']</so:publisher>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Goal/636799/134_48_212">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Goal"/>
    <so:textual_span>test the significance of quantitative results and the probability that the results were not a result of chance and showed a true reflection of the target population</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/636799/134"/>
    <so:begin_index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">48</so:begin_index>
    <so:end_index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">212</so:end_index>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/33011/407">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>In our data we identified various forms of sharing and exchanging information and materials that enthusiasts enacted to both help and inspire other enthusiasts to contribute to practice preservation. </so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/33011"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/publications_20d1a925-674f-4f69-8eff-4ed258dc2c2c/240">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>To efficiently resolve parking conflicts, we introduce the parking constraint and use disjoint splitting (Li et al. 2019a) to generate $ c_i \vee c_j $, namely </so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/publications_20d1a925-674f-4f69-8eff-4ed258dc2c2c"/>
  </rdf:Description>
