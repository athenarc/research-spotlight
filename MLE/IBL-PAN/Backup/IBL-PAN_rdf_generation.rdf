  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/636799/105">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>PANAS was developed to allow use of the scale repeatedly and/or within a longitudinal study; the researcher can insert different time periods from "present moment" to "past year" into the survey questions. </so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/636799"/>
  </rdf:Description>
