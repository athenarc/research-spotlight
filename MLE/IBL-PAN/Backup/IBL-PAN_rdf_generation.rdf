  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Mathematical_optimization_publications_20d1a925-674f-4f69-8eff-4ed258dc2c2c/298_56_70">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Mathematical optimization</so:method_name>
    <so:textual_span>MTPF algorithm</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/publications_20d1a925-674f-4f69-8eff-4ed258dc2c2c/298"/>
    <so:description>Mathematical optimization (alternatively spelled optimisation) or mathematical programming is the selection of a best element, with regard to some criteria, from some set of available alternatives. It is generally divided into two subfields: discrete optimization and continuous optimization.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=52033</so:wikipedia_url>
  </rdf:Description>
