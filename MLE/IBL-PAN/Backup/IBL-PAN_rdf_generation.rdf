    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/122533/137"/>
    <so:description>The American Chemical Society (ACS) is a scientific society based in the United States that supports scientific inquiry in the field of chemistry. Founded in 1876 at New York University, the ACS currently has more than 155,000 members at all degree levels and in all fields of chemistry, chemical engineering, and related fields.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=428508</so:wikipedia_url>
  </rdf:Description>
