  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Chronostratigraphy_442398/79_141_159">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Chronostratigraphy</so:method_name>
    <so:textual_span>chronostratigraphy</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/442398/79"/>
    <so:description>Chronostratigraphy is the branch of stratigraphy that studies the ages of rock strata in relation to time. The ultimate aim of chronostratigraphy is to arrange the sequence of deposition and the time of deposition of all rocks within a geological region, and eventually, the entire geologic record of the Earth.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=3433115</so:wikipedia_url>
  </rdf:Description>
