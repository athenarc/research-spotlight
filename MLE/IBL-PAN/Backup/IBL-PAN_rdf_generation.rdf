  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Disjoint_sets_publications_20d1a925-674f-4f69-8eff-4ed258dc2c2c/240_86_104">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Disjoint sets</so:method_name>
    <so:textual_span>disjoint splitting</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/publications_20d1a925-674f-4f69-8eff-4ed258dc2c2c/240"/>
    <so:description>In set theory in mathematics and formal logic, two sets are said to be disjoint sets if they have no element in common. Equivalently, two disjoint sets are sets whose intersection is the empty set.</so:description>
