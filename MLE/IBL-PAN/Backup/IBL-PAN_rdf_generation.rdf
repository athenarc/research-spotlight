  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/publications_20d1a925-674f-4f69-8eff-4ed258dc2c2c/296">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>In this paper, we showed that k-Robust MAPF (kR-MAPF) is a strict relaxation of Multi-Train Path Finding (MTPF). </so:sentence_text>
