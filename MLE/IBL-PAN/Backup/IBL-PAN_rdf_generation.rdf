  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/publications_20d1a925-674f-4f69-8eff-4ed258dc2c2c/304">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>We will also overcome the issue that current rectangle reasoning sometimes cannot remove all collision plans in one split to guarantee optimality. </so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/publications_20d1a925-674f-4f69-8eff-4ed258dc2c2c"/>
  </rdf:Description>
