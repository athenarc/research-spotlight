  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Differential_scanning_calorimetry_b3f5ede431eb4e63b5dcf75ef940187b/20_68_71">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Differential scanning calorimetry</so:method_name>
    <so:textual_span>DSC</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/b3f5ede431eb4e63b5dcf75ef940187b/20"/>
    <so:description>Differential scanning calorimetry (DSC) is a thermoanalytical technique in which the difference in the amount of heat required to increase the temperature of a sample and a reference is measured as a function of temperature. Both the sample and reference are maintained at nearly the same temperature throughout the experiment.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=97914</so:wikipedia_url>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Numerical_analysis_636799/126_127_161">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Numerical analysis</so:method_name>
    <so:textual_span>numerical and statistical analysis</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/636799/126"/>
    <so:description>Numerical analysis is the study of algorithms for the problems of continuous mathematics. These algorithms involve real or complex variables (in contrast to discrete mathematics), and typically use numerical approximation in addition to symbolic manipulation.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=21506</so:wikipedia_url>
  </rdf:Description>
