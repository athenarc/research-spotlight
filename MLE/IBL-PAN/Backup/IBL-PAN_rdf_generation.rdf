  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/publications_20d1a925-674f-4f69-8eff-4ed258dc2c2c/129">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>To start with, we construct an initial plan $ \pi $ where every agent $ a_i $ takes its shortest path, as computed by LLPP. </so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/publications_20d1a925-674f-4f69-8eff-4ed258dc2c2c"/>
