  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/122533/89">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>We apply the Hsieh and Klenow (2009) method for measuring the extent of factor misallocation within sectors. </so:sentence_text>
