  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/Robustness_(computer_science)_publications_20d1a925-674f-4f69-8eff-4ed258dc2c2c/296_30_53">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>Robustness (computer science)</so:method_name>
    <so:textual_span>k-Robust MAPF (kR-MAPF)</so:textual_span>
    <so:has_sentence_context rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/publications_20d1a925-674f-4f69-8eff-4ed258dc2c2c/296"/>
    <so:description>In computer science, robustness is the ability of a computer system to cope with errors during execution and cope with erroneous input. Robustness can encompass many areas of computer science, such as robust programming, robust machine learning, and Robust Security Network.</so:description>
    <so:wikipedia_url>https://en.wikipedia.org/wiki?curid=27206541</so:wikipedia_url>
  </rdf:Description>
  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Method/None_636799/114_30_35">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Method"/>
    <so:method_name>None</so:method_name>
    <so:textual_span>PANAS</so:textual_span>
