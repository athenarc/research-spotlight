    <so:sentence_text>It sought to maximize data collected and variation of data and be contextually applicable. </so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/636799"/>
