  <rdf:Description rdf:about="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Sentence/442398/120">
    <rdf:type rdf:resource="https://scholarlyontology.aueb.gr/resources/so_schema/so_MLE#Sentence"/>
    <so:sentence_text>As a result of applying the Levallois technique at the BC and VG, blades and flakes of very similar size and shape were formed (Sytnyk et al. 2010, figs. 7–9; Cyrek et al. 2014, fig. 22). </so:sentence_text>
    <so:is_part_of rdf:resource="https://scholarlyontology.aueb.gr/resources/so_instances/so_MLE#Article/442398"/>
  </rdf:Description>
